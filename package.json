{
  "name": "@neoli00/memx",
  "version": "2026.3.14",
  "description": "memX: self-learning, self-maintaining memory for AI agents.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "memx": "./dist/src/bin/memx.mjs",
    "memx-server": "./dist/src/bin/memx-server.mjs",
    "memx-mcp": "./dist/src/bin/memx-mcp.mjs",
    "memx-hook": "./dist/src/bin/memx-hook.mjs"
  },
  "files": [
    "dist",
    ".codex-plugin",
    ".claude-plugin",
    ".mcp.json",
    "hooks",
    "skills",
    "openclaw.plugin.json",
    "README.md",
    "README-ch.md",
    "ARCHITECTURE.md",
    "ARCHITECTURE-ch.md",
    "assets"
  ],
  "scripts": {
    "build": "tsdown index.ts src/bin/memx.ts src/bin/memx-server.ts src/bin/memx-mcp.ts src/bin/memx-hook.ts --no-config --clean --unbundle --root . --out-dir dist --format esm --target es2023 --platform node --no-treeshake --deps.never-bundle openclaw --deps.never-bundle openclaw/plugin-sdk/core --deps.never-bundle openclaw/plugin-sdk/process-runtime --dts --copy src/search/backends/sentence_transformers_embedder.py",
    "test": "node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "commander": "^14.0.3",
    "openclaw": "^2026.3.25",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.25"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/index.mjs"
    ],
    "install": {
      "npmSpec": "@neoli00/memx",
      "minHostVersion": ">=2026.3.25"
    },
    "compat": {
      "pluginApi": ">=2026.3.25",
      "minGatewayVersion": "2026.3.25"
    },
    "build": {
      "openclawVersion": "2026.3.25",
      "pluginSdkVersion": "2026.3.25"
    }
  }
}
